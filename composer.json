{
    "name": "nawasara/cloudflare",
    "description": "Cloudflare management dashboard for Nawasara — DNS records, zones, firewall rules, page rules, SSL settings, and analytics, with DB-cached snapshots and queue-backed mutations.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "cloudflare",
        "dns",
        "cdn",
        "firewall",
        "waf",
        "ssl",
        "analytics"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/cloudflare/issues",
        "source": "https://github.com/nawasara/cloudflare"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\Cloudflare\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-permission": "^6.0",
        "nawasara/ui": "*",
        "nawasara/sync": "*",
        "nawasara/vault": "*",
        "nawasara/registry": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Cloudflare\\CloudflareServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
